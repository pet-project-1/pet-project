VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 라즈베리파이가 Supabase Realtime broadcast 로 송출하는 디바이스 식별자.
# 토픽은 feeder:<id> — Pi 의 FEEDER_DEVICE_ID 와 정확히 일치해야 한다.
VITE_FEEDER_1_DEVICE_ID=feeder-1
VITE_FEEDER_2_DEVICE_ID=feeder-2

# 각 라즈베리파이의 로컬 HTTP API (smart_feeder/feeder_api.py) 베이스 URL.
# 미등록 개체 등록 모달에서 /pending, /register, /pending/<tid>/thumbnail 호출.
# 디바이스 ID 와 1:1 대응 — VITE_FEEDER_N_DEVICE_ID 와 같은 N 번 사용.
VITE_FEEDER_1_API_URL=http://192.168.0.10:8765
VITE_FEEDER_2_API_URL=http://192.168.0.11:8765

# Pi 측 FEEDER_API_TOKEN 과 일치. 비워두면 토큰 인증 안 함.
VITE_FEEDER_API_TOKEN=
